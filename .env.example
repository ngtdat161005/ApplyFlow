# Root example environment for ApplyFlow.
# Copy values into app-specific .env files when backend/frontend bootstrap tasks are implemented.

# Backend
PORT=4000
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=ApplyFlow
JWT_SECRET=replace-with-a-local-development-secret
FRONTEND_ORIGIN=http://localhost:5173
EMAIL_PROVIDER=console
RESEND_API_KEY=replace-with-a-resend-api-key
RESEND_FROM_EMAIL=no-reply@example.com
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
RESET_REQUEST_RATE_LIMIT_PER_EMAIL=5
RESET_REQUEST_RATE_LIMIT_EMAIL_WINDOW_MINUTES=15
RESET_REQUEST_RATE_LIMIT_PER_IP=20
RESET_REQUEST_RATE_LIMIT_IP_WINDOW_MINUTES=60

# Frontend
VITE_API_BASE_URL=http://localhost:4000
