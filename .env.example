# Safe example environment for ApplyFlow. Do not put real secrets in this file.
# When the backend starts from backend/, it loads root .env before backend/.env.

# Backend: required in every environment
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=applyflow_dev
JWT_SECRET=replace-with-a-local-development-secret
FRONTEND_ORIGIN=http://localhost:5173

# Backend: optional runtime mode (defaults to development)
NODE_ENV=development

# Backend: optional outside production. Production requires EMAIL_PROVIDER=resend.
# Console delivery is for local development/test and can expose a reset link in local logs.
EMAIL_PROVIDER=console
RESEND_API_KEY=replace-with-a-resend-api-key
RESEND_FROM_EMAIL=no-reply@example.test

# Backend: optional positive-integer overrides (defaults shown)
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
RESET_REQUEST_RATE_LIMIT_PER_EMAIL=5
RESET_REQUEST_RATE_LIMIT_EMAIL_WINDOW_MINUTES=15
RESET_REQUEST_RATE_LIMIT_PER_IP=20
RESET_REQUEST_RATE_LIMIT_IP_WINDOW_MINUTES=60

# Frontend: place in frontend/.env. /api uses the local Vite same-origin proxy.
VITE_API_BASE_URL=/api
